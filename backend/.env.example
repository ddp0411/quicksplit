# =============================================================================
# QuickSplit backend environment
# -----------------------------------------------------------------------------
# LOCAL DEV:   copy this file to `backend/.env` and fill in values.
# PRODUCTION:  set these as Variables in the Railway dashboard (NOT a committed
#              file). The "PRODUCTION (Railway)" notes below each var say what to
#              put there. Values are read in quicksplit/settings.py.
# Lists (ALLOWED_HOSTS, CORS_ORIGINS, CSRF_TRUSTED_ORIGINS) are comma-separated.
# =============================================================================

APP_NAME=QuickSplit API
APP_VERSION=1.0.0

# false in production. true only for local debugging.
DEBUG=true

# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# PRODUCTION (Railway): set a fresh long random value. Required when DEBUG=false.
SECRET_KEY=replace-with-a-long-random-secret

# Hostnames Django will serve (NO scheme, NO port, NO trailing slash).
# PRODUCTION (Railway): your Railway domain, e.g.
#   ALLOWED_HOSTS=quicksplit-production.up.railway.app
# Quick option that matches any Railway subdomain:  ALLOWED_HOSTS=.up.railway.app
# Add a custom API domain too when you have one:  ...,api.quicksplit.app
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Database --------------------------------------------------------------
# Local fallback (SQLite):   DATABASE_URL=sqlite:////tmp/quicksplit-local.db
# Local Postgres:            DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quicksplit
# Supabase (recommended) — copy from Supabase → Connect → Session pooler, then
# replace [YOUR-PASSWORD] (URL-encode special chars). Keep ?sslmode=require.
#   DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
# Pooler mode must match the port you used:
#   session pooler  (port 5432) -> DATABASE_POOL_MODE=session
#   transaction pooler (6543)   -> DATABASE_POOL_MODE=transaction
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quicksplit
DATABASE_POOL_MODE=session
DATABASE_SSL=false          # PRODUCTION (Supabase): true
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

# --- CORS / CSRF -----------------------------------------------------------
# CORS only matters for BROWSER clients. The mobile app (Bearer/JWT) does not
# need it. PRODUCTION: set to your landing/web origin(s) once live, e.g.
#   CORS_ORIGINS=https://quicksplit.app,https://www.quicksplit.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Needed for the Django /admin login POST over HTTPS. Full origin WITH scheme.
# PRODUCTION (Railway):  CSRF_TRUSTED_ORIGINS=https://quicksplit-production.up.railway.app
CSRF_TRUSTED_ORIGINS=

# --- AI assistant (set whichever provider key you have) --------------------
# Tried in order Groq -> Gemini -> Anthropic -> OpenAI. Groq has a free tier:
# create a key at https://console.groq.com (starts with gsk_). App runs without
# one; only the AI chat feature needs it.
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Uploads ---------------------------------------------------------------
UPLOAD_DIR=./uploads
DATASET_DIR=./dataset
MAX_UPLOAD_SIZE=10485760

# --- Redis / Celery (OPTIONAL — not used in V1; no tasks are defined) ------
# Leave unset in production. Only needed if you later add background jobs.
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2
