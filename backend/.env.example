APP_NAME=QuickSplit API
APP_VERSION=1.0.0
DEBUG=false

# Generate locally with:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-secret

# Local fallback:
# DATABASE_URL=sqlite:////tmp/quicksplit-local.db
#
# Local Postgres:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quicksplit
#
# Supabase Session Pooler recommended for local/dev IPv4:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quicksplit
DATABASE_POOL_MODE=session
DATABASE_SSL=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

# Redis is optional for local API use. If absent, the app degrades gracefully.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

UPLOAD_DIR=./uploads
DATASET_DIR=./dataset
MAX_UPLOAD_SIZE=10485760

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
